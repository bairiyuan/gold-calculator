{
  "compilerOptions": {
    "target": "ES2016",
    "module": "ESNext",
    "lib": ["ES2016", "DOM", "DOM.Iterable"],
    "outDir": "./",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["main.ts"],
  "exclude": ["node_modules"]
}